{
    "manifest_version": 3,
    "name": "Netflix Hindi Subtitles",
    "version": "1.0",
    "description": "Auto-translates Netflix subtitles to Hindi",
    "permissions": [
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://*.netflix.com/*",
        "https://*.nflxvideo.net/*",
        "https://translation.googleapis.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.netflix.com/*"
            ],
            "js": [
                "config.js",
                "content_script.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "https://www.netflix.com/*"
            ],
            "js": [
                "bridge.js"
            ],
            "run_at": "document_start",
            "world": "ISOLATED"
        }
    ]
}